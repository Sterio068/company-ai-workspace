# ========================================
# 企業 AI 工作台 · 環境變數範本
# 複製為 .env 後填入實際值
# .env 絕對不可進 git(已在 .gitignore)
# ========================================
#
# 變更紀錄:
#   2026-04-18 · 依 T-2 移除 rag-api 相關(POSTGRES / RAG_API_URL / EMBEDDINGS_*)
#   2026-04-18 · 依 S-1 標註機密欄位,生產環境改由 Keychain 注入
#
# ========================================
# 🔐 機密欄位處理原則(S-1)
# ========================================
# 生產環境請「不要」把 🔐 標記的值直接填進 .env:
# - macOS:存入 macOS Keychain,透過 scripts/start.sh 啟動時注入
# - Windows:存入 config-templates/.secrets/ 的 DPAPI 加密檔,透過 scripts/start-windows.ps1 注入
#
#   security add-generic-password -a $USER -s 'company-ai-openai-key' -w 'sk-xxx'
#   export OPENAI_API_KEY=$(security find-generic-password -s 'company-ai-openai-key' -w)
#
# 開發/測試環境可直接填在 .env,但「絕對不可」進 git。
# 詳見 docs/05-SECURITY.md「Keychain 機密管理」章節。
# 變數重要性分層見 config-templates/.env.tiers.md

# ==================== 基本設定 ====================
HOST=0.0.0.0
PORT=3080
NODE_ENV=production
ECC_ENV=production
ALLOW_LEGACY_AUTH_HEADERS=0

# 公開域名(Cloudflare Tunnel 指向的)
# ⚠ 預設 http://localhost · 開瀏覽器登入後直接能用
# 設好 Cloudflare Tunnel 後改成 https://ai.<公司domain>.com 並重啟
DOMAIN_CLIENT=http://localhost
DOMAIN_SERVER=http://localhost

# 不允許公開註冊(新同仁由管理員建立)
ALLOW_REGISTRATION=false
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false
ALLOW_EMAIL_LOGIN=true
ALLOW_PASSWORD_RESET=true

# ==================== 資料庫 ====================
MONGO_URI=mongodb://mongodb:27017/company_ai

# ==================== Meilisearch(全文檢索)====================
SEARCH=true
MEILI_NO_ANALYTICS=true
MEILI_HOST=http://meilisearch:7700
# 🔐 用 openssl rand -hex 32 產生
MEILI_MASTER_KEY=<GENERATE_WITH_openssl_rand_hex_32>

# ==================== LibreChat RAG / file_search ====================
# LibreChat v0.8+ 非圖片附件與 file_search 需要 RAG_API_URL。
# 公司版指向 accounting 內建 /rag adapter,不額外拉 pgvector/RAG image。
RAG_API_URL=http://accounting:8000/rag

# ==================== 安全金鑰 ====================
# 🔐 全部用 openssl rand -hex 32 產生,每個都不同
CREDS_KEY=<GENERATE_WITH_openssl_rand_hex_32>
CREDS_IV=<GENERATE_WITH_openssl_rand_hex_16>
JWT_SECRET=<GENERATE_WITH_openssl_rand_hex_32>
JWT_REFRESH_SECRET=<GENERATE_WITH_openssl_rand_hex_32>
# LibreChat Actions 低權限通行權杖；正式安裝由 scripts/setup-keychain.sh / start.sh 產生
ACTION_BRIDGE_TOKEN=<GENERATE_WITH_openssl_rand_hex_32>

# ==================== AI 模型 API Keys ====================
#
# OpenAI(主力 · 前端預設)
# 🔐 生產環境建議存 Keychain:
#   security add-generic-password -s 'company-ai-openai-key' -a $USER -w '...'
OPENAI_API_KEY=sk-<PASTE_YOUR_KEY>
OPENAI_MODELS=gpt-5.4,gpt-5.4-mini,gpt-5.4-nano

# Launcher 預設引擎(使用者仍可在前端切換)
COMPANY_AI_DEFAULT_AI_PROVIDER=openai

# Anthropic Claude(選配備援)
# 🔐 生產環境建議存 Keychain:
#   security add-generic-password -s 'company-ai-anthropic-key' -a $USER -w '...'
ANTHROPIC_API_KEY=
ANTHROPIC_MODELS=claude-opus-4-7,claude-sonnet-4-6,claude-haiku-4-5

# 🚀 Prompt Caching(Claude 備援使用時有效)
# Anthropic 的 cache_control 機制 · 靜態 prompt(Agent instructions + Company Memory)首次呼叫後 5 分鐘內免費
# 公司 10 人同時使用下,命中率高,月省幾千 NT$
ANTHROPIC_ENABLE_PROMPT_CACHE=true

# Extended Thinking(Claude Opus 深度思考 · 備援重大決策用)
ANTHROPIC_ENABLE_THINKING=true
ANTHROPIC_THINKING_BUDGET_TOKENS=10000

# ==================== NotebookLM Enterprise(選配 · 並行知識庫)====================
# 官方文件:
#   https://docs.cloud.google.com/gemini/enterprise/notebooklm-enterprise/docs/api-notebooks
#   https://docs.cloud.google.com/gemini/enterprise/notebooklm-enterprise/docs/api-notebooks-sources
# 注意:本地 MongoDB / 本地檔案仍是主資料庫；NotebookLM 只接收可審核資料包快照。
NOTEBOOKLM_ENTERPRISE_ENABLED=false
NOTEBOOKLM_PROJECT_NUMBER=
NOTEBOOKLM_LOCATION=global
NOTEBOOKLM_ENDPOINT_LOCATION=global
# 🔐 OAuth access token / Enterprise API token · 建議由部署腳本或 Keychain 注入,不要寫死在 repo
NOTEBOOKLM_ACCESS_TOKEN=

# ==================== Electron 自動更新 Proxy(私有 GitHub Release)====================
# App 只打 UPDATE_PROXY_URL + UPDATE_PROXY_TOKEN;GitHub token 只放 server-side。
# CI 打包正式 Electron app 時也會把前兩者寫入 extraResources/update-proxy.json。
VOTER_SERVICE_UPDATE_PROXY_URL=http://localhost
# 🔐 給已信任內部分發 app 使用的 proxy token;不要公開分享
VOTER_SERVICE_UPDATE_PROXY_TOKEN=
# 🔐 server-side GitHub token;只給 accounting/update proxy 使用,不可打進 app
UPDATE_PROXY_GITHUB_TOKEN=
UPDATE_PROXY_GITHUB_REPOSITORY=Sterio068/company-ai-workspace
UPDATE_PROXY_CACHE_TTL_SECONDS=60

# 禁用其他供應商(預設只開 OpenAI + Claude)
GOOGLE_KEY=
AZURE_API_KEY=
ASSISTANTS_API_KEY=

# ==================== 使用者上傳限制 ====================
# 這三項與 librechat.yaml 的 fileConfig 重複,env 為備援
FILE_UPLOAD_SIZE_LIMIT=50
FILE_UPLOAD_MIME_TYPES=image/*,application/pdf,text/*,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# ==================== 管理員初始帳號 ====================
# 月報自動寄信收件人 · 第一次登入 launcher 註冊時填的 email 會自動成為 ADMIN
# 設好 SMTP 之後改成公司實際 admin email · 如:boss@company.example.com
ADMIN_EMAIL=admin@company-ai.local

# ==================== 用量與成本 ====================
# 全公司月預算上限(USD)— 超過就暫停新對話
# 原規劃 NT$ 12,000,約 USD 400(以 1 USD = 30 TWD 粗估)
MONTHLY_BUDGET_USD=400

# 各使用者預設每月 token 上限(輕度 / 中度 / 重度 分別後台覆寫)
DEFAULT_USER_TOKEN_LIMIT=1500000
# (Claude Sonnet 4.6 下約 NT$ 800 的用量)

# ==================== 日誌 ====================
DEBUG_LOGGING=false
DEBUG_CONSOLE=false
LOG_LEVEL=info

# ==================== 會話設定 ====================
SESSION_EXPIRY=1000 * 60 * 60 * 24 * 7
# 一週

# ==================== 社交登入(全關閉)====================
GITHUB_CLIENT_ID=
GOOGLE_CLIENT_ID=
FACEBOOK_CLIENT_ID=

# ==================== Email(密碼重設用)====================
# 用 Gmail SMTP 或 Resend(二擇一)
EMAIL_SERVICE=resend
# 🔐 Resend API key 或 SMTP 密碼
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=ai@company-ai.local
EMAIL_FROM_NAME=企業 AI 工作台

# ==================== 移除說明 ====================
# 以下欄位因 docker-compose 移除外部 rag-api / vectordb / whisper 而不再需要:
#   POSTGRES_USER, POSTGRES_PASSWORD   (vectordb 容器移除)
#   EMBEDDINGS_PROVIDER,
#   EMBEDDINGS_MODEL,
#   EMBEDDINGS_DIMENSION                (外部 RAG image 移除)
# 注意:RAG_API_URL 仍需要,但現在指向 accounting 內建 /rag adapter。
# 若未來要外掛自訂 embedding 供應商,再從 docs/08-MCP-INTEGRATION.md 的升級路徑加回
